# LLM 配置 (兼容所有 OpenAI 接口协议的 LLM)
# 通义千问: OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 智谱:     OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
# DeepSeek: OPENAI_BASE_URL=https://api.deepseek.com
# Ollama:   OPENAI_BASE_URL=http://localhost:11434/v1
# OpenAI:   OPENAI_BASE_URL=https://api.openai.com/v1

# 以下三项为必填项,缺少任一项将报错
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL_NAME=qwen-turbo

# 可选
OPENAI_TEMPERATURE=0.1
EMBEDDING_MODEL_NAME=text-embedding-v3
